          }
        },
        {
          "name": "My feedback",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/feedback/mine",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },

            "method": "POST", "url": "{{baseUrl}}/api/support/admin/session/{{sessionId}}/join",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Admin — close session",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/support/admin/session/{{sessionId}}/close",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },

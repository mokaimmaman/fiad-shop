          }
        },
        {
          "name": "Send message",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/support/session/{{sessionId}}/message",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"sender\": \"user\", \"message\": \"Hello, is anyone there?\" }" }
          }
        },
        { "name": "Get session",  "request": { "method": "GET", "url": "{{baseUrl}}/api/support/session/{{sessionId}}" } },
        { "name": "Customer token", "request": { "method": "GET", "url": "{{baseUrl}}/api/support/token?sessionId={{sessionId}}" } },
        {
          "name": "Admin token",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/support/admin/token",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }

            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"FIAD-NEW-001\",\n  \"pid\": \"CJ-NEW-001\",\n  \"name\": \"New Test Product\",\n  \"description\": \"A test product created via API.\",\n  \"category\": \"Test\",\n  \"basePrice\": 29.99,\n  \"images\": [\"https://picsum.photos/600\"],\n  \"affiliateCommission\": 10,\n  \"stock\": 25,\n  \"variants\": [\n    { \"color\": \"Black\", \"size\": \"M\", \"stock\": 10 },\n    { \"color\": \"White\", \"size\": \"L\", \"stock\": 15 }\n  ]\n}" }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/admin/products/{{productId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"basePrice\": 34.99, \"isActive\": true }" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/admin/products/{{productId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Orders",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/admin/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Detail",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/admin/orders/ORDER_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]

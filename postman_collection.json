    {
      "name": "Admin — Email Providers",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/admin/email-providers",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]

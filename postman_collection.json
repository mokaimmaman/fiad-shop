{
  "info": {
    "name": "Fiad Shop API",
    "description": "Complete API surface for the Fiad Shop backend. Set the `baseUrl` collection variable to your local or Vercel URL (e.g. http://localhost:4000 or https://your-app.vercel.app). After logging in, the login/register requests automatically save `token` (and `adminToken`) into collection variables — every authenticated request then uses `{{token}}` in the Authorization header.\n\n**Auth cheat sheet:**\n- `{{token}}` — customer/affiliate JWT\n- `{{adminToken}}` — admin JWT (separate slot so you can hold both simultaneously)\n- `{{orderNumber}}` — auto-set after creating an order\n- `{{productId}}` — auto-set after listing products",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:4000", "type": "string" },
    { "key": "token",       "value": "",                        "type": "string" },
    { "key": "adminToken",  "value": "",                        "type": "string" },
    { "key": "orderNumber", "value": "",                        "type": "string" },
    { "key": "productId",   "value": "",                        "type": "string" },
    { "key": "sessionId",   "value": "",                        "type": "string" },
    { "key": "affiliateId", "value": "",                        "type": "string" },
    { "key": "feedbackId",  "value": "",                        "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Root",   "request": { "method": "GET", "url": "{{baseUrl}}/" } },
        { "name": "Health", "request": { "method": "GET", "url": "{{baseUrl}}/api/health" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.devOtp) { pm.collectionVariables.set('lastOtp', j.devOtp); console.log('devOtp:', j.devOtp); }"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"Password123!\",\n  \"displayName\": \"Alice Example\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.token) pm.collectionVariables.set('token', j.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user1@example.com\",\n  \"otp\": \"{{lastOtp}}\"\n}" }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/resend-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"user1@example.com\" }" }
          }
        },
        {
          "name": "Login (user)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.token) pm.collectionVariables.set('token', j.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Login (admin) — saves to {{adminToken}}",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.token) pm.collectionVariables.set('adminToken', j.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@fiad.shop\",\n  \"password\": \"ChangeMe123!\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"email\": \"user1@example.com\" }" }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"PASTE_RESET_TOKEN_FROM_EMAIL\",\n  \"password\": \"NewPassword456!\"\n}" }
          }
        },
        {
          "name": "2FA — setup",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/2fa/setup",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "2FA — verify & enable",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/2fa/verify-enable",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"code\": \"123456\" }" }
          }
        },
        {
          "name": "2FA — disable",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/2fa/disable",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Products (public)",
      "item": [
        {
          "name": "List",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.items && j.items[0]) pm.collectionVariables.set('productId', j.items[0].id);"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?limit=24" }
        },
        { "name": "Detail",  "request": { "method": "GET", "url": "{{baseUrl}}/api/products/{{productId}}" } },
        { "name": "By SKU",  "request": { "method": "GET", "url": "{{baseUrl}}/api/products/by-sku/FIAD-TSHIRT-001" } },
        { "name": "Search",  "request": { "method": "GET", "url": "{{baseUrl}}/api/products?q=shirt&sort=price-asc" } },
        { "name": "Homepage",   "request": { "method": "GET", "url": "{{baseUrl}}/api/settings/homepage" } },
        { "name": "Categories", "request": { "method": "GET", "url": "{{baseUrl}}/api/settings/categories" } },
        { "name": "Support status", "request": { "method": "GET", "url": "{{baseUrl}}/api/settings/support-status" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create (guest or user)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.order?.orderNumber) pm.collectionVariables.set('orderNumber', j.order.orderNumber);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/orders/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 1 }\n  ],\n  \"shippingAddress\": {\n    \"fullName\": \"Alice Example\",\n    \"email\": \"alice@example.com\",\n    \"phone\": \"+15551234567\",\n    \"line1\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"country\": \"United States\",\n    \"postalCode\": \"10001\"\n  },\n  \"promoCode\": null\n}" }
          }
        },
        {
          "name": "My orders",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/orders/mine",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Track (guest — needs email)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders/{{orderNumber}}/track?email=alice@example.com" }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        { "name": "Invoice status", "request": { "method": "GET", "url": "{{baseUrl}}/api/payment/status/INVOICE_ID" } }
      ]
    },
    {
      "name": "Affiliate",
      "item": [
        {
          "name": "Apply (any authed user)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/affiliate/apply",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/affiliate/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Set promo code (once)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/affiliate/promo-code",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"code\": \"ALICE10\" }" }
          }
        },
        {
          "name": "Create discount link",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/affiliate/discount-link",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"discountPercent\": 5, \"maxUses\": 100 }" }
          }
        },
        {
          "name": "List discount links",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/affiliate/discount-links",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Request withdrawal",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/affiliate/withdraw",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"amount\": 25.00, \"method\": \"USDT_TRC20\", \"destination\": \"TQ...wallet\" }" }
          }
        },
        {
          "name": "List withdrawals",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/affiliate/withdrawals",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Feedback",

# ============================================================================
# Fiad Shop Backend — Environment Variables
# Copy this file to .env.local (dev) and paste real values into Vercel dashboard
# for production. NEVER commit real secrets.
# ============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- Database (Supabase PostgreSQL) ------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&pgbouncer=true&connection_limit=1
# Optional direct connection for migrations (bypasses pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public

# --- Auth --------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Email: Brevo (primary) --------------------------------------------------
BREVO_API_KEY=YOUR_BREVO_API_KEY_HERE

# --- Email: Sendpulse (secondary / failover) ---------------------------------
SENDPULSE_API_KEY=YOUR_SENDPULSE_API_KEY_HERE
SENDPULSE_SECRET=YOUR_SENDPULSE_SECRET_HERE

# --- Ably (live support) -----------------------------------------------------
ABLY_API_KEY=YOUR_ABLY_API_KEY_HERE
ABLY_CHANNEL_NAME=fiad-live-support

# --- Mistral AI (chatbot) ----------------------------------------------------
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE
MISTRAL_MODEL=mistral-small-latest

# --- NOWPayments (crypto/Hawala Visa) ----------------------------------------
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY_HERE
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET_HERE

# --- CJ Dropshipping ---------------------------------------------------------
CJ_API_KEY=YOUR_CJ_API_KEY_HERE
CJ_API_BASE=https://developers.cjdropshipping.com/api2.0/v1

# --- Admin / Misc ------------------------------------------------------------
ADMIN_SECRET_PATH=/super-secret-admin-login
SUPPORT_EMAIL=support@fiad.shop
FROM_EMAIL=support@fiad.shop
FROM_NAME=Fiad Shop

# --- URLs --------------------------------------------------------------------
FRONTEND_URL=https://your-github-username.github.io/fiad-shop
BACKEND_URL=https://your-vercel-app.vercel.app

# Comma-separated list of allowed CORS origins (frontend URL + localhost for dev)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-github-username.github.io
